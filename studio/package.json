{
  "name": "pimcore-helpers-bundle",
  "type": "module",
  "scripts": {
    "dev-server": "NODE_ENV=development rsbuild dev",
    "build": "NODE_ENV=production rsbuild build",
    "lint": "eslint ./js",
    "lint-fix": "eslint ./js --fix",
    "lint-fix-watch": "nodemon --watch './js/**/*' --exec \"eslint ./js --fix --cache\" -e js,jsx,ts,tsx",
    "check-types": "tsc --noEmit",
    "check-types-watch": "tsc --noEmit --watch"
  },
  "license": "PEL",
  "private": true,
  "devDependencies": {
    "@module-federation/rsbuild-plugin": "^2.1.0",
    "@rsbuild/core": "^1.3.16",
    "@rsbuild/plugin-react": "^1.3.1",
    "@types/node": "^26.0.0",
    "@types/react-dom": "18.3.x",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.x",
    "nodemon": "^3.1.14",
    "prettier": "^3.6.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.x"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@pimcore/studio-ui-bundle": "^2026.1.2",
    "antd": "^5.22.x",
    "react": "18.3.x",
    "react-dom": "18.3.x"
  },
  "prettier": {
    "printWidth": 120
  }
}
